APP_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
# Optional comma-separated additional origins, without paths.
FRONTEND_ORIGINS=

# MongoDB Atlas: Database > Connect > Drivers
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=thap_rua_clinical

# OpenAI - backend only. Never expose this key through a VITE_* variable.
OPENAI_API_KEY=sk-proj_REPLACE_ME
OPENAI_MODEL=gpt-5.6-sol
OPENAI_BASE_URL=https://api.openai.com/v1

# Bounded in-process AI queue.
AI_JOB_WORKERS=4
AI_JOB_MAX_QUEUE=100
LLM_MAX_CONCURRENCY=4
