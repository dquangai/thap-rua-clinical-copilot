# Chon provider: openai | anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=replace_me

# Co the override endpoint cho Azure gateway/proxy OpenAI-compatible.
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=90
LLM_MAX_OUTPUT_TOKENS=12000

# USD / 1M tokens. Cap nhat theo bang gia/hop dong cua benh vien.
LLM_INPUT_PRICE_PER_MILLION_USD=0.40
LLM_OUTPUT_PRICE_PER_MILLION_USD=1.60

# Version bat bien cua pipeline/prompt dung de doi chieu cac run.
PIPELINE_VERSION=baseline-v1

# Mac dinh fail-closed: huy request neu van phat hien mau PII.
PII_FAIL_CLOSED=true
