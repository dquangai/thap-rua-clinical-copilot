# Chon provider: openai | anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
# Preferred standard variable for OpenAI. It may instead be exported by your shell/venv.
OPENAI_API_KEY=replace_me
# Generic fallback used by OpenAI-compatible providers or when OPENAI_API_KEY is unset.
LLM_API_KEY=replace_me

# Co the override endpoint cho Azure gateway/proxy OpenAI-compatible.
LLM_BASE_URL=https://api.openai.com/v1
LLM_USE_JSON_SCHEMA=true
LLM_TIMEOUT_SECONDS=90
LLM_MAX_OUTPUT_TOKENS=12000

# USD / 1M tokens. Cap nhat theo bang gia/hop dong cua benh vien.
LLM_INPUT_PRICE_PER_MILLION_USD=0.40
LLM_OUTPUT_PRICE_PER_MILLION_USD=1.60

# Version bat bien cua pipeline/prompt dung de doi chieu cac run.
PIPELINE_VERSION=compact-final-v4

# Mac dinh fail-closed: huy request neu van phat hien mau PII.
PII_FAIL_CLOSED=true

# So tieu chi toi da moi call LLM; cac batch chay song song. 0 = tat chia batch.
LLM_BATCH_SIZE=10

# Async AI jobs (single API instance). For horizontal scaling, replace with Redis/SQS workers.
AI_JOB_WORKERS=4
AI_JOB_MAX_QUEUE=100
# Process-wide cap for actual provider HTTP calls, including parallel batches inside each job.
LLM_MAX_CONCURRENCY=4
