{
  "name": "thap-rua-clinical-copilot",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend",
    "backend/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace @thap-rua/api run dev",
    "build": "npm --workspace frontend run build",
    "preview": "npm --workspace frontend run preview",
    "start:backend": "npm --workspace @thap-rua/api run start",
    "test:ai": "PYTHONPATH=backend/ai python -m unittest discover -s backend/ai/tests",
    "check:ai:dry": "PYTHONPATH=backend/ai python -m clinical_checker.cli --data data/sim_kham1.json --rules rules --dry-run",
    "check:ai": "PYTHONPATH=backend/ai python -m clinical_checker.cli --data data --rules rules --output results"
  },
  "devDependencies": {
    "lightningcss-darwin-arm64": "^1.32.0"
  }
}
